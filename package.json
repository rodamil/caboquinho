{
  "name": "caboquinho",
  "productName": "caboquinho",
  "version": "2.1.6",
  "description": "My Electron application description",
  "main": "dist/app.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/rodamil/caboquinho"
  },
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "echo \"No linting configured\"",
    "server": "node ./src/backend/index.js",
    "server:dev": "nodemon ./src/backend/index.js",
    "clean": "rimraf dist/",
    "copy-files": "copyfiles -u 1 src/**/*.html src/**/*.json src/**/*.ico src/**/*.txt dist/",
    "build": "npm run clean && tsc && npm run copy-files"
  },
  "keywords": [],
